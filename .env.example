# Kavach AI Environment Configuration Example

# Backend Environment
KAVACH_DEBUG=True
KAVACH_LOG_LEVEL=INFO
KAVACH_DATABASE_URL=sqlite:///data/kavach.db
# To use PostgreSQL, set the URL below:
# KAVACH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kavach_ai

# API Cors configuration
KAVACH_CORS_ORIGINS=http://localhost:3000

# Frontend Environment
NEXT_PUBLIC_API_URL=http://localhost:8000
